@{
    ViewData["Title"] = "Import Data";
}


<div class="row">
    <div class="">
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white" >
                <i class="fa-solid fa-keyboard"></i>
                Individual Entry
            </div>
            <div class="p-2">
                <form id="importDataForm" class="m-4">
                    <div class="row g-3">
                        <div class="col-md">
                            <label class="form-label fw-semibold">Mother Mold Code</label>
                            <input type="text" name="MotherMoldCode" class="form-control" placeholder="Enter mother mold code" required>
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Child Partcode</label>
                            <input type="text" name="ChildPartcode" class="form-control" placeholder="Enter part code" required>
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Part Name</label>
                            <input type="text" name="PartName" class="form-control" placeholder="Enter part name">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Supplier</label>
                            <input type="text" name="Supplier" class="form-control" placeholder="Enter supplier name">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Model</label>
                            <input type="text" name="Model" class="form-control" placeholder="Enter model name or number">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Mold Maker</label>
                            <input type="text" name="MoldMaker" class="form-control" placeholder="Enter mold maker name">
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md">
                            <label class="form-label fw-semibold">BIPH Mold No.</label>
                            <input type="text" name="BIPHMoldNo" class="form-control" placeholder="Enter BIPH mold number" required>
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Supplier Mold No.</label>
                            <input type="text" name="SupplierMoldNo" class="form-control" placeholder="Enter supplier mold number">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Tooling Management</label>
                            <input type="text" name="ToolingManagement" class="form-control">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Activity</label>
                            <input type="text" name="Activity" class="form-control">
                        </div>
                        <div class="col-md">
                            <label class="form-label fw-semibold">Reason of Change</label>
                            <input type="text" name="ReasonOfChange" class="form-control">
                        </div>

                        <div class="col-md">
                            <label class="form-label fw-semibold">Tooling Type</label>
                            <select name="ToolingType" class="form-select" required>
                                <option value="">-- Select Tooling Type --</option>
                                <option value="Injection">Injection (Tooling)</option>
                                <option value="Rubber Injection">Rubber Injection (Tooling)</option>
                                <option value="Stamping">Stamping (Tooling)</option>
                                <option value="N/A">N/A</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Tooling Category</label>
                            <select name="ToolingCategory" class="form-select">
                                <option value="">-- Select Tooling Category --</option>
                                <option value="Additional">Additional</option>
                                <option value="Renewal">Renewal</option>
                                <option value="New">New</option>
                                <option value="N/A">N/A</option>
                            </select>
                        </div>

                        <div class="col-md-9">
                            <label class="form-label fw-semibold">Applicable Activity</label>

                            <div class="dropdown w-100">
                                <button class="btn btn-light dropdown-toggle w-100 text-start text-wrap"
                                        type="button"
                                        id="activityDropdown"
                                        data-bs-toggle="dropdown">
                                    Select Applicable Activity
                                </button>

                                <ul class="dropdown-menu w-100 p-3">

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="RenewalAdditionalMold">
                                        <label class="form-check-label">Renewal / Additional Mold</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="NewToolingLocalization">
                                        <label class="form-check-label">New Tooling / Localization</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="TransferTooling">
                                        <label class="form-check-label">Transfer Tooling</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="ChangeMaterial">
                                        <label class="form-check-label">Change Material</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="NewModel">
                                        <label class="form-check-label">New Model</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="NonConcurrent">
                                        <label class="form-check-label">Non-Concurrent</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="SupplierChangeLocalization">
                                        <label class="form-check-label">Supplier Change / Localization</label>
                                    </li>

                                    <li class="form-check">
                                        <input class="form-check-input activity-check" type="checkbox" data-field="Other4M">
                                        <label class="form-check-label">Other 4M</label>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <input type="hidden" name="RenewalAdditionalMold" value="NO">
                        <input type="hidden" name="NewToolingLocalization" value="NO">
                        <input type="hidden" name="TransferTooling" value="NO">
                        <input type="hidden" name="ChangeMaterial" value="NO">
                        <input type="hidden" name="NewModel" value="NO">
                        <input type="hidden" name="NonConcurrent" value="NO">
                        <input type="hidden" name="SupplierChangeLocalization" value="NO">
                        <input type="hidden" name="Other4M" value="NO">

                        
                    </div>

                    <div class="row mt-4">
                        <div class="col text-end">
                            <div class="d-inline-flex gap-2">
                                <button type="submit" class="btn btn-success" style="width: 150px;">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> Save
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="">
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <i class="fa-solid fa-keyboard"></i>
                Batch Entry
            </div>
            <div class="p-2">
                <div class="row g-3">
                    <!-- Buttons (Bottom Right) -->
                    <div class="row mt-4 mb-4">
                        <div class="col text-start">
                            <div class="d-inline-flex gap-2">

                                @* Download template *@
                                <a asp-action="DownloadImportTemplate"
                                   asp-controller="ImportData"
                                   class="btn btn-outline-success">
                                    Download Excel Template
                                </a>

                                @* Upload excel template *@
                                <button class="btn btn-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#uploadExcelModal">
                                    <i class="fa-solid fa-file-arrow-up me-1"></i> Upload Data
                                </button>

                                @* Export *@
                                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exportModal">
                                    <i class="fa-solid fa-file-export me-1"></i> Export Data
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">

                    <!-- Display Table -->
                    <div class="col-12">
                        <div class="table-responsive mt-4">
                            <table class="table table-bordered" id="previewTable">
                                <thead class="table-light text-center">
                                    <tr>
                                        <th>#</th>
                                        <th>Control No</th>
                                        <th>Mother Mold</th>
                                        <th>Child Part</th>
                                        <th>Part Name</th>
                                        <th>Model</th>
                                        <th>Supplier</th>
                                        <th>Mold Maker</th>
                                        <th>Supplier Mold No.</th>
                                        <th>BIPH Mold No.</th>
                                        <th>Tooling Management</th>
                                        <th>Renewal / Additional Mold</th>
                                        <th>New Tooling / Localization</th>
                                        <th>Transfer Tooling</th>
                                        <th>Change Material</th>
                                        <th>New Model</th>
                                        <th>Non-Concurrent</th>
                                        <th>Supplier Change / Localization</th>
                                        <th>Other 4M</th>
                                        <th>Reason of Change</th>

                                    </tr>
                                </thead>
                                <tbody class="fs-6"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Buttons (Bottom Right) -->
                    <div class="row mt-4">
                        <div class="col text-end">
                            <div class="d-inline-flex gap-2">
                                <button class="btn btn-primary" id="importBatchBtn">
                                    <i class="fa-solid fa-upload me-1"></i> Import Batch
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Data Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <!-- ✅ Centered -->
        <div class="modal-content">
            <form id="exportForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="exportModalLabel">Export Data</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="date" id="startDate" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="date" id="endDate" class="form-control" required>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Export</button>
                </div>
            </form>
        </div>
    </div>
</div>




@* Modal for excel batch upload *@
<div class="modal fade" id="uploadExcelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-file-excel text-success me-1"></i>
                    Upload Template
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="excelUploadForm" enctype="multipart/form-data">

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Select Excel File</label>
                        <input type="file"
                               name="excelFile"
                               class="form-control"
                               accept=".xlsx,.xls"
                               required />
                        <small class="text-muted">
                            Allowed file: .xlsx / .xls
                        </small>
                    </div>
                </div>]

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fa-solid fa-eye me-1"></i> Preview
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

                 
@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        /* ===============================
           Applicable Activity Logic
        ================================ */

        document.querySelectorAll(".activity-check").forEach(cb => {
            cb.addEventListener("change", function () {
                const field = this.dataset.field;
                const hidden = document.querySelector(`input[name='${field}']`);

                if (hidden) {
                    hidden.value = this.checked ? "YES" : "NO";
                }

                updateActivityText();
            });
        });

        function updateActivityText() {
            const selected = Array.from(document.querySelectorAll(".activity-check:checked"))
                .map(cb => cb.nextElementSibling.innerText.trim());

            const btn = document.getElementById("activityDropdown");

            btn.innerText = selected.length
                ? selected.join(", ")
                : "Select Applicable Activity";

            // ✅ force wrap (important for long text)
            btn.style.whiteSpace = "normal";
            btn.style.wordBreak = "break-word";
            btn.style.lineHeight = "1.3";
        }

        function resetActivitySelections() {
            document.querySelectorAll(".activity-check").forEach(cb => cb.checked = false);

            document.querySelectorAll(
                "input[name='RenewalAdditionalMold'], \
                 input[name='NewToolingLocalization'], \
                 input[name='TransferTooling'], \
                 input[name='ChangeMaterial'], \
                 input[name='NewModel'], \
                 input[name='NonConcurrent'], \
                 input[name='SupplierChangeLocalization'], \
                 input[name='Other4M']"
            ).forEach(h => h.value = "NO");

            const btn = document.getElementById("activityDropdown");
            btn.innerText = "Select Applicable Activity";
            btn.style.whiteSpace = "normal";
        }

        /* ===============================
           AJAX Form Submit
        ================================ */

        document.getElementById("importDataForm").addEventListener("submit", function (e) {
            e.preventDefault();

            // ✅ Collect form data
            const formData = new FormData(this);
            const data = {};
            formData.forEach((value, key) => data[key] = value);

            // Check at least one activity is selected
            const checkedActivities = Array.from(document.querySelectorAll(".activity-check:checked"))
                                           .map(cb => cb.nextElementSibling.innerText.trim());

            if (checkedActivities.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Warning',
                    text: 'Please select at least one Applicable Activity.'
                });
                return;
            }

            // Replace hidden activity values with the checked ones
            data.ApplicableActivity = checkedActivities.join(", ");

            // ✅ Build HTML table for confirmation
            let tableHtml = '<table class="table table-bordered table-striped">';
            tableHtml += '<thead><tr><th>Field</th><th>Value</th></tr></thead><tbody>';

            for (let key in data) {
                if (key.startsWith("Renewal") || key.startsWith("NewTooling") || key.startsWith("TransferTooling") ||
                    key.startsWith("ChangeMaterial") || key.startsWith("NewModel") || key.startsWith("NonConcurrent") ||
                    key.startsWith("SupplierChange") || key === "Other4M") {
                    // // Show only checked activities as YES
                    // if (data[key] === "YES") {
                    //     tableHtml += `<tr><td>${key}</td><td>YES</td></tr>`;
                    // }
                } else {
                    tableHtml += `<tr><td>${key}</td><td>${data[key]}</td></tr>`;
                }
            }
            

            tableHtml += '</tbody></table>';

            // ✅ Show confirmation modal
            Swal.fire({
                title: 'Confirm Submission',
                html: tableHtml,
                width: '600px',
                showCancelButton: true,
                confirmButtonText: 'Yes, Save',
                cancelButtonText: 'Cancel',
                focusConfirm: false,
                customClass: {
                    popup: 'swal2-overflow' // ensure scroll if content is long
                }
            }).then((result) => {
                if (result.isConfirmed) {

                    const saveUrl = '@Url.Action("SaveImportData","ImportData")';

                    // Submit via fetch
                     fetch(saveUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken':
                                document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(res => {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Saved!',
                                text: res.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                            document.getElementById("importDataForm").reset();
                            resetActivitySelections();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: res.message
                            });
                        }
                    })
                    .catch(err => {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: err
                        });
                    });
                }
            });
        });


    </script>


    @* To preview template data in table *@
    <script>
        $(document).ready(function () {

            $('#excelUploadForm').on('submit', function (e) {
                e.preventDefault();

                let formData = new FormData(this);

                const previewUrl = '@Url.Action("PreviewExcelTemplate", "ImportData")';

                $.ajax({
                    url: previewUrl,
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (data) {

                        $('#uploadExcelModal').modal('hide');

                        let tbody = $('#previewTable tbody');
                        tbody.empty();

                        if (!data || data.length === 0) {
                            alert('No data found in Excel.');
                            return;
                        }

                        $.each(data, function (index, item) {
                            tbody.append(`
                                <tr>
                                    <td>${index + 1}</td>
                                    <td>${item.controlNo ?? ''}</td>
                                    <td>${item.motherMoldCode ?? ''}</td>
                                    <td>${item.childPartcode ?? ''}</td>
                                    <td>${item.partName ?? ''}</td>
                                    <td>${item.model ?? ''}</td>
                                    <td>${item.supplier ?? ''}</td>
                                    <td>${item.moldMaker ?? ''}</td>
                                    <td>${item.supplierMoldNo ?? ''}</td>
                                    <td>${item.biphMoldNo ?? ''}</td>
                                    <td>${item.toolingManagement ?? ''}</td>
                                    <td>${item.renewalAdditionalMold ?? ''}</td>
                                    <td>${item.newToolingLocalization ?? ''}</td>
                                    <td>${item.transferTooling ?? ''}</td>
                                    <td>${item.changeMaterial ?? ''}</td>
                                    <td>${item.newModel ?? ''}</td>
                                    <td>${item.nonConcurrent ?? ''}</td>
                                    <td>${item.supplierChangeLocalization ?? ''}</td>
                                    <td>${item.other4M ?? ''}</td>
                                    <td>${item.reasonOfChange ?? ''}</td>
                                </tr>
                            `);
                        });
                    },
                    error: function (xhr) {
                        console.error(xhr.responseText);
                        alert('Failed to read Excel file.');
                    }
                });
            });

        });
    </script>

    @* Import batch data from table *@
    <script>
        document.getElementById("importBatchBtn").addEventListener("click", function () {
            const table = document.getElementById("previewTable");
            const rows = table.querySelectorAll("tbody tr");
            if (rows.length === 0) {
                Swal.fire("No Data", "There is no data to import.", "warning");
                return;
            }

            // 🔹 Build JSON from table rows
            const data = Array.from(rows).map(row => {
                const cells = row.querySelectorAll("td");
                return {
                    ControlNo: cells[1].innerText.trim(),
                    MotherMoldCode: cells[2].innerText.trim(),
                    ChildPartcode: cells[3].innerText.trim(),
                    PartName: cells[4].innerText.trim(),
                    Model: cells[5].innerText.trim(),
                    Supplier: cells[6].innerText.trim(),
                    MoldMaker: cells[7].innerText.trim(),
                    SupplierMoldNo: cells[8].innerText.trim(),
                    BIPHMoldNo: cells[9].innerText.trim(),
                    ToolingManagement: cells[10].innerText.trim(),
                    RenewalAdditionalMold: cells[11].innerText.trim(),
                    NewToolingLocalization: cells[12].innerText.trim(),
                    TransferTooling: cells[13].innerText.trim(),
                    ChangeMaterial: cells[14].innerText.trim(),
                    NewModel: cells[15].innerText.trim(),
                    NonConcurrent: cells[16].innerText.trim(),
                    SupplierChangeLocalization: cells[17].innerText.trim(),
                    Other4M: cells[18].innerText.trim(),
                    ReasonOfChange: cells[19].innerText.trim()
                };
            });

            Swal.fire({
                title: "Confirm Import",
                text: `Are you sure you want to import ${data.length} rows?`,
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes, Import",
                cancelButtonText: "Cancel"
            }).then(result => {
                if (result.isConfirmed) {
                    fetch('@Url.Action("ImportExcelBatch", "ImportData")', {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(resp => {
                        if (resp.success) {
                            Swal.fire("Imported", resp.message || "Data imported successfully!", "success")
                            .then(() => location.reload()); // optional reload
                        } else {
                            Swal.fire("Error", resp.message || "Failed to import data.", "error");
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        Swal.fire("Error", "Server error occurred.", "error");
                    });
                }
            });
        });
    </script>

    <script>
        document.getElementById("exportForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const start = document.getElementById("startDate").value;
            const end = document.getElementById("endDate").value;

            // ✅ Basic validation
            if (!start || !end) {
                toastr.warning("Please select both start and end dates.");
                return;
            }

            if (start > end) {
                toastr.warning("Start date cannot be after end date.");
                return;
            }

            // Build URL with query params
            const url = '@Url.Action("ExportData", "ImportData")?start=' + encodeURIComponent(start) + '&end=' + encodeURIComponent(end);

            try {
                // Fetch the file
                const response = await fetch(url);

                if (!response.ok) {
                    // If server returns 404, 500, etc.
                    toastr.error("No data found for the selected date range or server error occurred.");
                    return;
                }

                const blob = await response.blob();

                // Create temporary link to trigger download
                const downloadUrl = window.URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = downloadUrl;

                // Optional: extract filename from content-disposition header
                const disposition = response.headers.get("content-disposition");
                let filename = "ExportedData.xlsx";
                if (disposition && disposition.includes("filename=")) {
                    filename = disposition.split("filename=")[1].replace(/"/g, '');
                }
                a.download = filename;

                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(downloadUrl);

                // ✅ Success toast
                toastr.success("Export completed successfully!");

                // Close modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
                modal.hide();

            } catch (err) {
                console.error(err);
                toastr.error("An error occurred while exporting the data.");
            }
        });
    </script>

}



