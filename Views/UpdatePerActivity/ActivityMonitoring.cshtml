@model IEnumerable<PartsControlSystem.Models.ViewActivityMonitoring>

@{
    ViewData["Title"] = "Activity Monitoring";
}

<div class="card shadow-sm mb-3 border-0">
    <div class="card-body py-2">
        <div class="row align-items-center g-2">
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Select Activity</label>
                <select id="activitySelect" class="form-select form-select-sm">
                    <option value="Renewal / Additional Mold">Renewal / Additional Mold</option>
                    <option value="New Tooling / Localization">New Tooling / Localization</option>
                    <option value="Supplier Change / Localization">Supplier Change / Localization</option>
                    <option value="Multiple Procurement / Localization">Multiple Procurement / Localization</option>
                    <option value="Transfer Tooling">Transfer Tooling</option>
                    <option value="Change Material">Change Material</option>
                    <option value="New Model">New Model</option>
                    <option value="Non-Concurrent">Non-Concurrent</option>
                    <option value="Other 4M">Other 4M</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Monitoring table container — Renewal loads by default -->
<div id="monitoringContainer">
    <partial name="Partials/Monitoring/_RenewalMonitoring" model="Model" />
</div>

<script>
    document.getElementById('activitySelect').addEventListener('change', function () {
        const activity = this.value;
        const container = document.getElementById('monitoringContainer');

        container.innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2 text-muted small">Loading monitoring data...</div>
            </div>`;

        fetch('@Url.Action("GetMonitoringPartial", "UpdatePerActivity")'
            + '?activity=' + encodeURIComponent(activity))
            .then(res => res.text())
            .then(html => { container.innerHTML = html; })
            .catch(() => {
                container.innerHTML = `
                    <div class="alert alert-danger text-center mt-3">
                        Failed to load monitoring data.
                    </div>`;
            });
    });
</script>
