@model PartsControlSystem.ViewModels.ActivityImportViewModel

<div class="container-fluid px-4 mt-4">

    <!-- FILTER CARD -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Section</label>
                    <input type="text" id="sectionInput"
                           class="form-control form-control-sm"
                           value="@User.FindFirst("Section")?.Value"
                           readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Selected Activity</label>
                    <input type="text"
                           id="activityInput"
                           class="form-control form-control-sm"
                           readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Process</label>
                    <select id="processSelect" class="form-select form-select-sm">
                        <option value="" disabled selected>Select Process</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button type="button" id="refreshDataBtn" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-rotate-right"></i> Refresh
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div id="activityPartialContainer">


    </div>

    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Write Activity name in input field *@
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const params = new URLSearchParams(window.location.search);
            const activityName = params.get('activityName');

            if (activityName) {
                document.getElementById('activityInput').value = activityName;
            }
        });
    </script>

    <script>
        document.getElementById('refreshDataBtn').addEventListener('click', function () {

            const section  = document.getElementById('sectionInput').value;
            const activity = document.getElementById('activityInput').value;
            const process  = document.getElementById('processSelect').value;

            console.log(process);

            if (!section || !activity || !process) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Required',
                    text: 'Section, Activity, and Process are required.'
                });
                return;
            }

            fetch(`@Url.Action("GetPartial", "UpdatePerActivity")`
                + `?section=${encodeURIComponent(section)}`
                + `&activity=${encodeURIComponent(activity)}`
                + `&process=${encodeURIComponent(process)}`)
                .then(res => res.text())
                .then(html => {

                    // 🔹 Backend returns marker when no data
                    if (html.includes('NO_DATA')) {
                        Swal.fire({
                            icon: 'info',
                            title: 'No Activity',
                            text: 'No activity for update yet.'
                        });

                        document.getElementById('activityPartialContainer').innerHTML = '';
                        return;
                    }

                    document.getElementById('activityPartialContainer').innerHTML = html;
                });
        });
    </script>



    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const section = document.getElementById("sectionInput").value;
            const processSelect = document.getElementById("processSelect");

            if (!section) return;

            fetch('@Url.Action("GetActivitiesBySection", "UpdatePerActivity")'
            + '?section=' + encodeURIComponent(section))
            .then(res => res.json())
            .then(activities => {

                // clear existing options
                processSelect.innerHTML = '';

                // default option
                const defaultOption = document.createElement('option');
                defaultOption.value = '';
                defaultOption.textContent = 'Select process';
                defaultOption.disabled = true;  
                defaultOption.selected = true;
                processSelect.appendChild(defaultOption);

                // populate activities only
                activities.forEach(activity => {
                    const opt = document.createElement('option');
                    opt.value = activity;
                    opt.textContent = activity;
                    processSelect.appendChild(opt);
                });
            });
        });
    </script>

   <script>
       document.addEventListener('click', function (e) {

            const btn = e.target.closest('.btn-save-approval');
            if (!btn) return;

            const card = btn.closest('.card');

            const endpoint = card.dataset.endpoint;
            const controlNumber = card.dataset.controlno;
            const fields = card.dataset.fields.split(',');

            const payload = {
                ControlNumber: controlNumber
            };

            let hasError = false;

            fields.forEach(field => {
                const input = card.querySelector(`[name="${field}"]`);
                if (!input) return;

                if (input.hasAttribute('required') && !input.value) {
                    hasError = true;
                }

                payload[field] = input.value || null;
            });

            if (hasError) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Required Fields',
                    text: 'Please complete all required fields.'
                });
                return;
            }

            Swal.fire({
                title: 'Save changes?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Save'
            }).then(result => {

                if (!result.isConfirmed) return;

                fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                .then(r => {
                    if (!r.ok) throw new Error();
                    return r.json();
                })
                .then(() => {
                    Swal.fire({
                        icon: 'success',
                        title: 'Saved',
                        text: 'Data saved successfully.',
                        timer: 1500,
                        showConfirmButton: false
                    });

                    card.remove();
                })
                .catch(() => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Unable to save data.'
                    });
                });
            });
        });

