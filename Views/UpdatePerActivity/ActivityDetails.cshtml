@model PartsControlSystem.ViewModels.ActivityImportViewModel

<div class="container-fluid px-4 mt-4">

    <!-- FILTER CARD -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Section</label>
                    <input type="text" id="sectionInput"
                           class="form-control form-control-sm"
                           value="@User.FindFirst("Section")?.Value"
                           readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Selected Activity</label>
                    <input type="text" id="activityInput"
                           class="form-control form-control-sm"
                           readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Process</label>
                    <select id="processSelect" class="form-select form-select-sm">
                        <option value="" disabled selected>Select Process</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="button" id="refreshDataBtn" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-rotate-right"></i> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="activityPartialContainer"></div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ── Activity routing constants ──────────────────────────────────────
        const NEW_TOOLING_ACTIVITIES = [
            'New Tooling / Localization',
            'Supplier Change / Localization',
            'Multiple Procurement / Localization'
        ];

        const CHANGE_MATERIAL_ACTIVITIES = ['Change Material'];

        const OTHER4M_ACTIVITIES = ['Other 4M']

        // ── On page load ────────────────────────────────────────────────────
                document.addEventListener("DOMContentLoaded", () => {
            const params       = new URLSearchParams(window.location.search);
            const activityName = params.get('activityName');

            if (activityName) {
                document.getElementById('activityInput').value = activityName;
            }

            if (NEW_TOOLING_ACTIVITIES.includes(activityName)) {
                loadProcessesByActivity(activityName);   // ← ADD THIS — was missing
            } else if (CHANGE_MATERIAL_ACTIVITIES.includes(activityName)) {
                loadChangeMaterialProcesses();
            } else if (OTHER4M_ACTIVITIES.includes(activityName)) {
                loadOther4MProcesses();
            } else {
                loadProcessesBySection();
            }
        });

        // ── Renewal path: load from LeadTimes by section ────────────────────
        function loadProcessesBySection() {
            const section       = document.getElementById("sectionInput").value;
            const processSelect = document.getElementById("processSelect");
            if (!section) return;

            fetch('@Url.Action("GetActivitiesBySection", "UpdatePerActivity")'
                + '?section=' + encodeURIComponent(section))
                .then(res => res.json())
                .then(activities => {
                    processSelect.innerHTML = '';
                    const defaultOpt = document.createElement('option');
                    defaultOpt.value       = '';
                    defaultOpt.textContent = 'Select process';
                    defaultOpt.disabled    = true;
                    defaultOpt.selected    = true;
                    processSelect.appendChild(defaultOpt);

                    activities.forEach(activity => {
                        const opt       = document.createElement('option');
                        opt.value       = activity;
                        opt.textContent = activity;
                        processSelect.appendChild(opt);
                    });
                });
        }

        // ── New Tooling / Supplier Change / Multiple Procurement path ───────
        function loadProcessesByActivity(activityName) {
            const section       = document.getElementById("sectionInput").value;
            const processSelect = document.getElementById("processSelect");
            if (!section) return;

            fetch('@Url.Action("GetProcessesByActivity", "UpdatePerActivity")'
                + '?section='      + encodeURIComponent(section)
                + '&activityName=' + encodeURIComponent(activityName))
                .then(res => res.json())
                .then(processes => {
                    processSelect.innerHTML = '';
                    const defaultOpt = document.createElement('option');
                    defaultOpt.value       = '';
                    defaultOpt.textContent = 'Select process';
                    defaultOpt.disabled    = true;
                    defaultOpt.selected    = true;
                    processSelect.appendChild(defaultOpt);

                    processes.forEach(p => {
                        const opt       = document.createElement('option');
                        opt.value       = p.processStep;
                        opt.textContent = p.processStep;
                        processSelect.appendChild(opt);
                    });
                });
        }

        // ── Change Material path ─────────────────────────────────────────────
            function loadChangeMaterialProcesses() {
                const section       = document.getElementById("sectionInput").value;
                const processSelect = document.getElementById("processSelect");

                fetch('@Url.Action("GetChangeMaterialProcesses", "UpdatePerActivity")'
                    + '?section=' + encodeURIComponent(section))

                .then(res => res.json())
                .then(processes => {
                    processSelect.innerHTML = '';
                    const defaultOpt       = document.createElement('option');
                    defaultOpt.value       = '';
                    defaultOpt.textContent = 'Select process';
                    defaultOpt.disabled    = true;
                    defaultOpt.selected    = true;
                    processSelect.appendChild(defaultOpt);

                    processes.forEach(p => {
                        const opt       = document.createElement('option');
                        opt.value       = p.processStep;
                        opt.textContent = p.processStep;
                        processSelect.appendChild(opt);
                    });
                });
        }

                // ── Other 4M path (fixed 13-step sequence, no section variation) ────
        function loadOther4MProcesses() {
            const processSelect = document.getElementById("processSelect");

            fetch('@Url.Action("GetOther4MProcesses", "UpdatePerActivity")')
                .then(res => res.json())
                .then(processes => {
                    processSelect.innerHTML = '';
                    const defaultOpt = document.createElement('option');
                    defaultOpt.value = '';
                    defaultOpt.textContent = 'Select process';
                    defaultOpt.disabled = true;
                    defaultOpt.selected = true;
                    processSelect.appendChild(defaultOpt);

                    processes.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.processStep;
                        opt.textContent = p.processStep;
                        processSelect.appendChild(opt);
                    });
                });
        }

        // ── Refresh button ───────────────────────────────────────────────────
        document.getElementById('refreshDataBtn').addEventListener('click', function () {
            const section      = document.getElementById('sectionInput').value;
            const activity     = document.getElementById('activityInput').value;
            const process      = document.getElementById('processSelect').value;
            const isNewTooling = NEW_TOOLING_ACTIVITIES.includes(activity);
            const isChangeMat  = CHANGE_MATERIAL_ACTIVITIES.includes(activity);
            const isOther4M    = OTHER4M_ACTIVITIES.includes(activity);

            if (!section || !activity || !process) {
                Swal.fire({ icon: 'warning', title: 'Required', text: 'Section, Activity, and Process are required.' });
                return;
            }

            const container = document.getElementById('activityPartialContainer');
            container.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>';

            let url;

            if (isNewTooling) {
                url = '@Url.Action("GetNewToolingPartial", "UpdatePerActivity")'
                    + '?section='      + encodeURIComponent(section)
                    + '&activityName=' + encodeURIComponent(activity)
                    + '&process='      + encodeURIComponent(process);
                    } else if (isChangeMat) {
            url = '@Url.Action("GetChangeMaterialPartial", "UpdatePerActivity")'
                + '?process=' + encodeURIComponent(process);
            } else if (isOther4M) {
                url = '@Url.Action("GetOther4MPartial", "UpdatePerActivity")'
                    + '?process=' + encodeURIComponent(process);
            } else {
                url = '@Url.Action("GetPartial", "UpdatePerActivity")'
                    + '?section='  + encodeURIComponent(section)
                    + '&activity=' + encodeURIComponent(activity)
                    + '&process='  + encodeURIComponent(process);
            }

            fetch(url)
                .then(res => res.text())
                .then(html => { container.innerHTML = html; })
                .catch(() => { container.innerHTML = '<div class="alert alert-danger">Failed to load data.</div>'; });
        });

        // ── Universal save handler ───────────────────────────────────────────
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-save-approval');
            if (!btn) return;

            const card     = btn.closest('.card');
            const endpoint = card.dataset.endpoint;
            const fields   = card.dataset.fields.split(',');

            const payload = { ControlNumber: card.dataset.controlno };

            if (card.dataset.activityname) payload.ActivityName = card.dataset.activityname;
            if (card.dataset.category)     payload.Category     = card.dataset.category;
            if (card.dataset.processstep)  payload.ProcessStep  = card.dataset.processstep;
            if (card.dataset.steporder)    payload.StepOrder    = parseInt(card.dataset.steporder);

            let hasError = false;
            fields.forEach(field => {
                const input = card.querySelector(`[name="${field}"]`);
                if (!input) return;
                if (input.hasAttribute('required') && !input.value) hasError = true;
                payload[field] = input.value || null;
            });

            if (hasError) {
                Swal.fire({ icon: 'warning', title: 'Required Fields', text: 'Please complete all required fields.' });
                return;
            }

            Swal.fire({
                title: 'Save changes?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Save'
            }).then(result => {
                if (!result.isConfirmed) return;

                fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                .then(r => {
                    if (!r.ok) throw new Error();
                    return r.json();
                })
                .then(() => {
                    Swal.fire({
                        icon: 'success', title: 'Saved',
                        text: 'Data saved successfully.',
                        timer: 1500, showConfirmButton: false
                    });
                    card.remove();
                })
                .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Unable to save data.' }));
            });
        });
    </script>

</div>