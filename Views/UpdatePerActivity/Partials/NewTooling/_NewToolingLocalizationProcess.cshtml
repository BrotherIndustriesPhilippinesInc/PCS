@functions {
    string GetFields(int stepOrder, bool isSC, bool isLOC) => (stepOrder, isSC, isLOC) switch
    {
        // ── STEP 1 ──
        (1, false, false) => "TargetDate,Result,ReferenceNo,Remarks",
        (1, true, false) => "TargetDate,Result,ReferenceNo,Remarks",
        (1, false, true) => "TargetDate,Remarks",

        // ── STEP 2 ──
        (2, false, false) => "TargetDate,Result,Remarks",
        (2, true, false) => "TargetDate,Result,Remarks",
        (2, false, true) => "TargetDate,ReferenceNo,Remarks",

        // ── STEP 3 ──
        (3, false, false) => "TargetDate,Remarks",
        (3, true, false) => "ActualDate,Remarks",
        (3, false, true) => "TargetDate,Remarks",

        // ── STEP 4 ── Target only all
        (4, _, _) => "TargetDate,Remarks",

