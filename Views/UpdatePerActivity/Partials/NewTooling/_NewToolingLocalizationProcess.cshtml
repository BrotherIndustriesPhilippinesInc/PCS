@model IEnumerable<PartsControlSystem.ViewModels.NewToolingLocalizationProcessVM>

@foreach (var item in Model)
{
    var stepOrder = item.StepOrder;
    var activityName = item.ActivityName;
    var isSC = activityName == "Supplier Change / Localization";
    var isMP = activityName == "Multiple Procurement / Localization";
    var isLOC = activityName == "New Tooling / Localization";

    <div class="card shadow-sm border-0 mb-4 process-card"
         data-endpoint="@Url.Action("SaveNewToolingLocalizationProcess", "UpdatePerActivity")"
         data-controlno="@item.ControlNumber"
         data-activityname="@item.ActivityName"
         data-category="@item.Category"
         data-processstep="@item.ProcessStep"
         data-steporder="@item.StepOrder"
         data-fields="@GetFields(stepOrder, isSC, isLOC)">

        <div class="card-header d-flex justify-content-between align-items-center"
             style="background:#4a5568; border-radius:12px 12px 0 0;">
            <span class="text-white fw-semibold">
                @item.ActivityName &mdash; @item.ProcessStep
            </span>
            <span class="badge bg-light text-dark">
                @item.Category &nbsp;|&nbsp; Step @item.StepOrder
            </span>
        </div>

        <div class="card-body">

            <div class="row g-3 mb-2">
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Control No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ControlNumber" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Section</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Section" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Tooling Type</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingType" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Category</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingCategory" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Model</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Model" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Part Code</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ChildPartcode" readonly />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Part Name</label>
                    <input type="text" class="form-control form-control-sm" value="@item.PartName" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Tooling Mgt. No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingManagement" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Supplier</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Supplier" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">BIPH Mold No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.BIPHMoldNo" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Supplier Mold No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.SupplierMoldNo" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Mold Maker</label>
                    <input type="text" class="form-control form-control-sm" value="@item.MoldMaker" readonly />
                </div>
            </div>

            <hr class="my-2" />

            <div class="row g-3 mb-2">

                @* ══════════════════════════════════════════
                   STEP 1
                   MP/SC → Target + BIPH to New Supplier + Old Supplier to BIPH dropdowns
                   LOC   → Target only (Tooling PO Issued Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 1 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">BIPH to New Supplier</label>
                        <select name="Result" class="form-select form-select-sm" style="background-color:#fffbe6;">
                            <option value="">-- Select --</option>
                            <option value="Completed" @@(item.Result= ="Completed" ? "selected" : "" )>Completed</option>
                            <option value="Not Yet" @@(item.Result= ="Not Yet" ? "selected" : "" )>Not Yet</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Old Supplier to BIPH</label>
                        <select name="ReferenceNo" class="form-select form-select-sm" style="background-color:#fffbe6;">
                            <option value="">-- Select --</option>
                            <option value="Completed" @@(item.ReferenceNo= ="Completed" ? "selected" : "" )>Completed</option>
                            <option value="Not Yet" @@(item.ReferenceNo= ="Not Yet" ? "selected" : "" )>Not Yet</option>
                        </select>
                    </div>
                }
                @if (stepOrder == 1 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 2
                   MP/SC → Target + Status dropdown (Material LOA)
                   LOC   → Date + Revision text (Drawing Issuance to Supplier)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 2 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <select name="Result" class="form-select form-select-sm" style="background-color:#fffbe6;">
                            <option value="">-- Select --</option>
                            <option value="Completed" @@(item.Result= ="Completed" ? "selected" : "" )>Completed</option>
                            <option value="Not Yet" @@(item.Result= ="Not Yet" ? "selected" : "" )>Not Yet</option>
                        </select>
                    </div>
                }
                @if (stepOrder == 2 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Revision</label>
                        <input type="text" name="ReferenceNo" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" placeholder="e.g. A, B, Rev1..."
                               value="@item.ReferenceNo" />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 3
                   MP  → Target only (Manual FC)
                   SC  → Actual only (Manual FC)
                   LOC → Target only (Tooling Transfer Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 3 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 3 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date <span class="text-danger">*</span></label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 3 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 4 — Target only (all activities)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 4)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 5
                   MP/SC → Target only (Tooling Transfer Date)
                   LOC   → Target + Actual (PH Sample Submission)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 5 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 5 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 6
                   MP/SC → Target only (4M Application Date)
                   LOC   → Target + Actual (PH Sample Approval)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 6 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 6 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 7
                   MP/SC → Target + Actual (Kataken Submission)
                   LOC   → Type Change text only (Procurement Type Change)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 7 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 7 && isLOC)
                {
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Type Change <span class="text-danger">*</span></label>
                        <input type="text" name="ReferenceNo" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" placeholder="e.g. Localization, Special Proc..."
                               value="@item.ReferenceNo" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 8
                   MP/SC → Target + Actual (Kataken Approval)
                   LOC   → Target only (Open Sourcelist Local)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 8 && (isMP || isSC))
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 8 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 9
                   MP  → Target + PPS Approval Date
                   SC  → Actual only (DE Sample Received)
                   LOC → Target only (Test Run PO Request Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 9 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">PPS Approval Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 9 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date <span class="text-danger">*</span></label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 9 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 10
                   MP  → Target only (Open Sourcelist)
                   SC  → Target + Actual (DE Sample Approval)
                   LOC → Target only (Test Run PO Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 10 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 10 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 10 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 11
                   MP  → Target + Type Change text
                   SC  → Actual only (QA Sample Received)
                   LOC → Actual only (Test Run Delivery Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 11 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Type Change</label>
                        <input type="text" name="ReferenceNo" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" placeholder="e.g. NEW MOLD, SPECIAL PROC..."
                               value="@item.ReferenceNo" />
                    </div>
                }
                @if (stepOrder == 11 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date <span class="text-danger">*</span></label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 11 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date <span class="text-danger">*</span></label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 12
                   MP  → Target only (Test Run PO Request)
                   SC  → Target + Actual (QA Sample Approval)
                   LOC → Start Date only (Test Run Schedule)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 12 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }
                @if (stepOrder == 12 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Actual Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 12 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Start Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                }

                @* ══════════════════════════════════════════
                   STEP 13
                   MP  → Target + Need/No Need dropdown
                   SC  → Target + PPS Approval Date
                   LOC → Target + Actual (Test Run Approval Date)
                ══════════════════════════════════════════ *@
                @if (stepOrder == 13 && isMP)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Need / No Need</label>
                        <select name="Result" class="form-select form-select-sm" style="background-color:#fffbe6;">
                            <option value="">-- Select --</option>
                            <option value="Need" @@(item.Result= ="Need" ? "selected" : "" )>Need</option>
                            <option value="No Need" @@(item.Result= ="No Need" ? "selected" : "" )>No Need</option>
                        </select>
                    </div>
                }
                @if (stepOrder == 13 && isSC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">PPS Approval Date</label>
                        <input type="date" name="ActualDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.ActualDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                }
                @if (stepOrder == 13 && isLOC)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Target Date <span class="text-danger">*</span></label>
                        <input type="date" name="TargetDate" class="form-control form-control-sm"
                               style="background-color:#fffbe6;" value="@(item.TargetDate?.ToString("yyyy-MM-dd"))" required />
                    </div>
                    <div class="col-md-3">
