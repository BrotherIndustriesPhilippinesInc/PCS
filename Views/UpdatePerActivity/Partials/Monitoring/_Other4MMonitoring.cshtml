@model IEnumerable<PartsControlSystem.Models.ViewOther4MMonitoring>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-sm align-middle text-nowrap">
                <thead class="text-center">
                <thead class="text-center">

                    <!-- ═══ ROW 1: GROUP HEADERS ═══ -->
                    <tr>
                        <th rowspan="3" class="sticky-col align-middle"
                            style="background:#4C4C4C;color:white;min-width:160px;">
                            Control No
                        </th>
                        <th colspan="43" style="background:#4FC1C8;color:white;">IQC</th>
                    </tr>

                    <!-- ═══ ROW 2: PROCESS NAMES ═══ -->
                    <tr>
                        <th colspan="2" style="background:#4FC1C8;color:white;">TEST RUN MEETING DATE</th>
                        <th colspan="5" style="background:#4FC1C8;color:white;">KATAKEN EVALUATION</th>
                        <th colspan="7" style="background:#F4B8C1;">DE EVALUATION</th>
                        <th colspan="5" style="background:#F4B8C1;">EE EVALUATION</th>
                        <th colspan="7" style="background:#E8A0C8;">SPECIAL QA EVALUATION</th>
                        <th colspan="3" style="background:#FFD966;">INVENTORY TRANSACTION FORM (ITF)</th>
                        <th colspan="3" style="background:#FFD966;">Delivery PO</th>
                        <th colspan="2" style="background:#FFD966;">Test Run PO</th>
                        <th colspan="5" style="background:#FFD966;">TEST RUN</th>

                        <!-- These now span 2 rows since there are no sub-columns -->
                        <th rowspan="2" class="align-middle" style="background:#F4A020;color:white;">IMPLEMENTATION DATE</th>
                        <th rowspan="2" class="align-middle" style="background:#F4A020;color:white;">FIRST DELIVERY DATE</th>
                    </tr>

                    <!-- ═══ ROW 3: SUB-COLUMNS ═══ -->
                    <tr>
                        <!-- Test Run Meeting Date -->
                        <th style="background:#4FC1C8;color:white;">TARGET</th>
                        <th style="background:#4FC1C8;color:white;">ACTUAL</th>

                        <!-- Kataken Evaluation -->
                        <th rowspan="2" style="background:#4FC1C8;color:white;">REQUESTED DATE</th>
                        <th rowspan="2" style="background:#4FC1C8;color:white;">SUBMISSION DATE</th>
                        <th rowspan="2" style="background:#4FC1C8;color:white;">APPROVED DATE</th>
                        <th rowspan="2" style="background:#4FC1C8;color:white;">KATAKEN STATUS</th>
                        <th rowspan="2" style="background:#4FC1C8;color:white;">REMARKS</th>

                        <!-- DE Evaluation -->
                        <th rowspan="2" style="background:#F4B8C1;">REFERENCE NO.</th>
                        <th rowspan="2" style="background:#F4B8C1;">WORKFLOW / SYSTEM NO.</th>
                        <th rowspan="2" style="background:#F4B8C1;">ACTUAL PARTS RECEIVED DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">PARTS ENDORSEMENT DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">ACTUAL FINISHED DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">DE EVAL STATUS</th>
                        <th rowspan="2" style="background:#F4B8C1;">REMARKS</th>

                        <!-- EE Evaluation -->
                        <th rowspan="2" style="background:#F4B8C1;">ACTUAL PARTS RECEIVED DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">PARTS ENDORSEMENT DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">ACTUAL FINISHED DATE</th>
                        <th rowspan="2" style="background:#F4B8C1;">EE EVAL STATUS</th>
                        <th rowspan="2" style="background:#F4B8C1;">REMARKS</th>

                        <!-- Special QA Evaluation -->
                        <th rowspan="2" style="background:#E8A0C8;">WORKFLOW NO.</th>
                        <th rowspan="2" style="background:#E8A0C8;">TARGET DELIVERY DATE</th>
                        <th rowspan="2" style="background:#E8A0C8;">ACTUAL PARTS RECEIVED DATE</th>
                        <th rowspan="2" style="background:#E8A0C8;">PARTS ENDORSEMENT DATE</th>
                        <th rowspan="2" style="background:#E8A0C8;">ACTUAL FINISHED DATE</th>
                        <th rowspan="2" style="background:#E8A0C8;">QA EVAL STATUS</th>
                        <th rowspan="2" style="background:#E8A0C8;">REMARKS</th>

                        <!-- ITF -->
                        <th rowspan="2" style="background:#FFD966;">ACTUAL FINISHED DATE</th>
                        <th rowspan="2" style="background:#FFD966;">ITF STATUS</th>
                        <th rowspan="2" style="background:#FFD966;">REMARKS</th>

                        <!-- Delivery PO -->
                        <th rowspan="2" style="background:#FFD966;">Request of Delivery PO</th>
                        <th rowspan="2" style="background:#FFD966;">PO issuance</th>
                        <th rowspan="2" style="background:#FFD966;">TARGET DELIVERY DATE</th>

                        <!-- Test Run PO -->
                        <th rowspan="2" style="background:#FFD966;">Test Run PO Request date</th>
                        <th rowspan="2" style="background:#FFD966;">PO issuance</th>

                        <!-- Test Run -->
                        <th rowspan="2" style="background:#FFD966;">TEST RUN NO.</th>
                        <th rowspan="2" style="background:#FFD966;">ACTUAL RECEIVED DATE TEST RUN PARTS</th>
                        <th rowspan="2" style="background:#FFD966;">ACTUAL FINISHED DATE</th>
                        <th rowspan="2" style="background:#FFD966;">TEST RESULT</th>
                        <th rowspan="2" style="background:#FFD966;">REMARKS</th>

                        <!-- NOTE: No th's here for Implementation Date and First Delivery Date
                             because they already used rowspan="2" in Row 2 above -->
                    </tr>

                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="100" class="text-center text-muted py-4">
                                <i class="fa-solid fa-inbox me-2"></i>No Other 4M records found.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <!-- Control No -->
                            <td class="sticky-col fw-bold text-center"
                                style="background:#4C4C4C;color:white;">
                                @item.ControlNumber
                            </td>

                            <!-- Test Run Meeting Date -->
                            <td class="text-center">@item.test_run_meeting_target?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.test_run_meeting_actual?.ToLocalTime().ToString("MM/dd/yyyy")</td>

                            <!-- Kataken Evaluation -->
                            <td class="text-center">@item.kataken_requested_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.kataken_submission_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.kataken_approved_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.kataken_status))
                                {
                                    <span class="badge @(item.kataken_status == "Approved" ? "bg-success" : "bg-warning text-dark")">
                                        @item.kataken_status
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.kataken_remarks</td>

                            <!-- DE Evaluation -->
                            <td class="text-center">@item.de_reference_no</td>
                            <td class="text-center">@item.de_workflow_system_no</td>
                            <td class="text-center">@item.de_parts_received_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.de_parts_endorsement_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.de_actual_finished_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.de_eval_status))
                                {
                                    <span class="badge @(item.de_eval_status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                        @item.de_eval_status
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.de_remarks</td>

                            <!-- EE Evaluation -->
                            <td class="text-center">@item.ee_parts_received_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.ee_parts_endorsement_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.ee_actual_finished_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.ee_eval_status))
                                {
                                    <span class="badge @(item.ee_eval_status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                        @item.ee_eval_status
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.ee_remarks</td>

                            <!-- Special QA Evaluation -->
                            <td class="text-center">@item.qa_workflow_no</td>
                            <td class="text-center">@item.qa_target_delivery_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.qa_parts_received_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.qa_parts_endorsement_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.qa_actual_finished_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.qa_eval_status))
                                {
                                    <span class="badge @(item.qa_eval_status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                        @item.qa_eval_status
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.qa_remarks</td>

                            <!-- ITF -->
                            <td class="text-center">@item.itf_actual_finished_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.itf_status))
                                {
                                    <span class="badge @(item.itf_status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                        @item.itf_status
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.itf_remarks</td>

                            <!-- Delivery PO -->
                            <td class="text-center">@item.delivery_po_request_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.delivery_po_issuance_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.delivery_po_target_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>

                            <!-- Test Run PO -->
                            <td class="text-center">@item.test_run_po_request_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.test_run_po_issuance_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>

                            <!-- Test Run -->
                            <td class="text-center">@item.test_run_no</td>
                            <td class="text-center">@item.test_run_actual_received_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">@item.test_run_actual_finished_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.test_result))
                                {
                                    <span class="badge @(item.test_result == "OK" ? "bg-success" : item.test_result == "NG" ? "bg-danger" : "bg-warning text-dark")">
                                        @item.test_result
                                    </span>
                                }
                            </td>
                            <td class="text-center">@item.test_run_remarks</td>

                            <!-- Implementation Date -->
                            <td class="text-center">@item.implementation_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>


                            <!-- First Delivery Date -->
                            <td class="text-center">@item.first_delivery_date?.ToLocalTime().ToString("MM/dd/yyyy")</td>
 
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .sticky-col {
        position: sticky;
        left: 0;
        z-index: 3;
        min-width: 160px;
    }
</style>
