@model IEnumerable<PartsControlSystem.ViewModels.MP2ToolingRequestOrderVM>

@foreach (var item in Model)
{
    <div class="card shadow-sm mb-3 border-0"
         data-controlno="@item.ControlNo"
         data-endpoint="@Url.Action("SaveMP2ActivityUpdate", "UpdatePerActivity")"
         data-fields="TRFNo,TargetDate,ActualDate,Remarks">

        <div class="card-header py-2 bg-secondary text-white fw-semibold small">
            MP2 – Tooling Request Order
        </div>

        <div class="card-body py-3">

            <!-- ROW 1 -->
            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Control No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ControlNo" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Section</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Section" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Tooling Type</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingType" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Category</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingCategory" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Model</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Model" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Part Code</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ChildPart" readonly />
                </div>


            </div>

            <!-- ROW 2 -->
            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Part Name</label>
                    <input type="text" class="form-control form-control-sm" value="@item.PartName" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Tooling Mgt. No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.ToolingManagement" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Supplier</label>
                    <input type="text" class="form-control form-control-sm" value="@item.Supplier" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">BIPH Mold No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.BiphMoldNo" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Supplier Mold No.</label>
                    <input type="text" class="form-control form-control-sm" value="@item.SupplierMoldNo" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Mold Maker</label>
                    <input type="text" class="form-control form-control-sm" value="@item.MoldMaker" readonly />
                </div>
            </div>

            <!-- Divider -->
            <div class="border-top my-2"></div>

            <!-- ROW 3 -->
            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <label class="form-label small mb-1">Limit Date</label>
                    <input type="date" class="form-control form-control-sm" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Remaining Days</label>
                    <input type="text" class="form-control form-control-sm" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">TRF No.</label>
                    <input type="text" 
                        class="form-control form-control-sm" 
                        name="TRFNo"
                        style="background-color: #FFF4B6; color: #333333" required/>
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Target Approval Date</label>
                    <input type="date" 
                        class="form-control form-control-sm"
                        name="TargetDate"
                        style="background-color: #FFF4B6; color: #333333" required/>
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Actual Approval Date</label>
                    <input type="date" 
                        class="form-control form-control-sm"
                        name="ActualDate"
                        style="background-color: #FFF4B6; color: #333333" required/>
                </div>

                <div class="col-md-2">
                    <label class="form-label small mb-1">Remarks</label>
                    <textarea 
                        class="form-control form-control-sm"
                        name="Remarks"
                        rows="2"></textarea>
                </div>
            </div>
        
            <!-- ACTION ROW -->
            <div class="row mt-3">
                <div class="col text-end">
                    <button type="button"
                            class="btn btn-sm btn-success btn-save-approval">
                        <i class="fa-solid fa-save me-1"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}
