    <script>
                // ── Declare table variable OUTSIDE so functions can access it ──
        var table;

        // ── These functions must be OUTSIDE $(document).ready ──
        function updateCount() {
            if (!table || !table.page) return;
            var info = table.page.info();
            $('#recordCount').text(info.recordsDisplay + ' records');
        }

        function updateCustomInfo() {
            if (!table || !table.page) return;
            var info = table.page.info();
            var text = 'Showing ' + (info.recordsDisplay === 0 ? 0 : info.start + 1)
                + ' to ' + info.end
                + ' of ' + info.recordsDisplay + ' records';
            if (info.recordsDisplay !== info.recordsTotal) {
                text += ' (filtered from ' + info.recordsTotal + ' total entries)';
            }
            $('#customInfo').text(text);
        }

        function renderCustomPaginate() {
            if (!table || !table.page) return;
            var info        = table.page.info();
            var totalPages  = info.pages;
            var currentPage = info.page;
            var html        = '';

            html += '<span class="paginate_button ' + (currentPage === 0 ? 'disabled' : '') + '" id="pgPrev">Previous</span>';

            for (var i = 0; i < totalPages; i++) {
                if (
                    i === 0 ||
                    i === totalPages - 1 ||
                    (i >= currentPage - 1 && i <= currentPage + 1)
                ) {
                    html += '<span class="paginate_button ' + (i === currentPage ? 'current' : '') + '" data-page="' + i + '">' + (i + 1) + '</span>';
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    html += '<span class="paginate_button disabled">…</span>';
                }
            }

            html += '<span class="paginate_button ' + (currentPage >= totalPages - 1 ? 'disabled' : '') + '" id="pgNext">Next</span>';

            var $p = $('#customPaginate');
            $p.html(html);

            $p.find('[data-page]').on('click', function () {
                table.page(parseInt($(this).data('page'))).draw('page');
            });
            $p.find('#pgPrev').on('click', function () {
                if (currentPage > 0) table.page('previous').draw('page');
            });
            $p.find('#pgNext').on('click', function () {
                if (currentPage < totalPages - 1) table.page('next').draw('page');
            });
        }

           $(document).ready(function () {

        table = $('#transactionTable').DataTable({
            paging:      true,
            pageLength:  10,
            lengthMenu:  [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
            ordering:    true,
            info:        true,
            scrollX:     false,
            autoWidth:   false,
            dom:         '<"tlog-dt-top"l>t',
            columnDefs:  [{ targets: 14, orderable: false, searchable: false }],
            language: {
                emptyTable:  'No records found.',
                zeroRecords: 'No matching records found.',
                info:        'Showing _START_ to _END_ of _TOTAL_ records',
                infoEmpty:   'Showing 0 to 0 of 0 records',
                lengthMenu:  'Show _MENU_ entries'
            },
                    initComplete: function () {
            setTimeout(function () {
                updateCount();
                updateCustomInfo();
                renderCustomPaginate();
            }, 100);
        },
        drawCallback: function () {
            updateCount();
            updateCustomInfo();
            renderCustomPaginate();
        }
        });


            // ── Search ──
            function applySearch() {
                var col   = $('#searchField').val();
                var value = $('#searchValue').val();
                table.columns().search('');
                if (value) {
                    col !== null && col !== ''
                        ? table.column(parseInt(col)).search(value)
                        : table.search(value);
                } else {
                    table.search('');
                }
                table.draw();
            }
            $('#searchValue').on('input', applySearch);
            $('#searchField').on('change', applySearch);

            // ── Date helpers ──
            function parseCellDate(str) {
                if (!str || str.trim() === '—') return null;
                var parts = str.trim().split('/');
                if (parts.length !== 3) return null;
                var month = parseInt(parts[0]), day = parseInt(parts[1]), year = parseInt(parts[2]);
                if (isNaN(month) || isNaN(day) || isNaN(year)) return null;
                return new Date(year, month - 1, day, 0, 0, 0, 0);
            }
            function parseInputDate(str) {
                if (!str) return null;
                var parts = str.split('-');
                if (parts.length !== 3) return null;
                var year = parseInt(parts[0]), month = parseInt(parts[1]), day = parseInt(parts[2]);
                if (isNaN(year) || isNaN(month) || isNaN(day)) return null;
                return new Date(year, month - 1, day, 0, 0, 0, 0);
            }

            // ── Date filter ──
            $.fn.dataTable.ext.search.push(function (settings, data) {
                var startInput = $('#filterStartDate').val();
                var endInput   = $('#filterEndDate').val();
                if (!startInput && !endInput) return true;

                var rowStartDate = parseCellDate(data[7]);
                if (!rowStartDate) return false;

                var filterStart = parseInputDate(startInput);
                var filterEnd   = parseInputDate(endInput);

                if (filterStart && filterEnd)
                    return rowStartDate >= filterStart && rowStartDate <= filterEnd;
                if (filterStart && !filterEnd)
                    return rowStartDate >= filterStart;
                if (!filterStart && filterEnd)
                    return rowStartDate <= filterEnd;

                return true;
            });
            $('#filterStartDate, #filterEndDate').on('change', function () { table.draw(); });

            // ── Download ──
            $('#btnDownload').on('click', function () {
                var headers = [];
                $('#transactionTable thead tr th').each(function (i) {
                    if (i < 14) headers.push($(this).text().trim());
                });
                var rows = [];
                table.rows({ search: 'applied', page: 'all' }).every(function () {
                    var $row = $(this.node());
                    var rowValues = [];
                    $row.find('td').each(function (i) {
                        if (i < 14) rowValues.push($(this).text().trim());
                    });
                    rows.push(rowValues);
                });
                var wsData    = [headers].concat(rows);
                var ws        = XLSX.utils.aoa_to_sheet(wsData);
                var colWidths = headers.map(function (h, i) {
                    var maxLen = h.length;
                    rows.forEach(function (row) {
                        var cellLen = (row[i] || '').toString().length;
                        if (cellLen > maxLen) maxLen = cellLen;
                    });
                    return { wch: Math.min(maxLen + 4, 50) };
                });
                ws['!cols'] = colWidths;
                var wb      = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Transaction Logs');
                var today   = new Date();
                var dateStr = today.getFullYear()
                    + ('0' + (today.getMonth() + 1)).slice(-2)
                    + ('0' + today.getDate()).slice(-2);
                XLSX.writeFile(wb, 'TransactionLogs_' + dateStr + '.xlsx');
            });
        });

