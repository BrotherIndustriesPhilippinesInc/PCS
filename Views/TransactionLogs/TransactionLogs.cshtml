@model List<PartsControlSystem.ViewModels.TransactionLogViewModel>
@{
    ViewData["Title"] = "Transaction Logs";
}

@* ── Search / Filter Bar ── *@
<div class="filter-card">
    <div class="filter-row">
        <span class="filter-label">Search</span>
        <select class="filter-select" id="searchField">
            <option selected disabled>-- Select --</option>
            <option value="0">Transaction No</option>
            <option value="1">Part Name</option>
            <option value="2">Supplier</option>
            <option value="3">Model</option>
            <option value="4">Activity</option>
            <option value="6">PIC</option>
        </select>
        <div class="search-wrap">
            <span class="search-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </span>
            <input class="search-input" type="text" id="searchValue" placeholder="Type to search..." autocomplete="off" />
        </div>
        <div class="date-group">
            <span class="date-label">Start Date</span>
            <input class="date-input" type="date" id="filterStartDate" />
            <span class="date-label">End Date</span>
            <input class="date-input" type="date" id="filterEndDate" />
        </div>
        <button class="dl-btn" id="btnDownload" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download
        </button>
    </div>
</div>

@* ── Table Card ── *@
<div class="tlog-card">
    <div class="tlog-header">
        <div class="tlog-title">All Logs</div>
    </div>

    <div class="tlog-table-wrap">
        <table id="transactionTable" class="table table-sm mb-0">
            <thead>
                <tr>
                    <th>Transaction No</th>
                    <th>Part Name</th>
                    <th>Supplier</th>
                    <th>Model</th>
                    <th>Activity</th>
                    <th>Source</th>
                    <th>PIC</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Received Date</th>
                    <th>Input Date</th>
                    <th>Current Process</th>
                    <th>Status</th>
                    <th>Remarks</th>
                    <th>History</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model ?? new List<PartsControlSystem.ViewModels.TransactionLogViewModel>())
                {
                    <tr>
                        <td class="tlog-mono">@log.TransactionNumber</td>
                        <td>@log.PartName</td>
                        <td>@log.Supplier</td>
                        <td>@log.Model</td>
                        <td><span class="tlog-badge-activity">@log.Activity</span></td>
                        <td>
                            @if (log.Source == "Import File")
                            {
                                <span class="tlog-source-import">Import File</span>
                            }
                            else
                            {
                                <span class="tlog-source-activity">Update Activity</span>
                            }
                        </td>
                        <td>@log.PIC</td>
                        <td class="col-date">@(log.StartDate.HasValue ? log.StartDate.Value.ToLocalTime().ToString("MM/dd/yyyy") : "—")</td>
                        <td class="col-date">@(log.EndDate.HasValue ? log.EndDate.Value.ToLocalTime().ToString("MM/dd/yyyy") : "—")</td>
                        <td class="col-date">@(log.ReceivedDate.HasValue ? log.ReceivedDate.Value.ToLocalTime().ToString("MM/dd/yyyy") : "—")</td>
                        <td class="col-date">@(log.InputDate.HasValue ? log.InputDate.Value.ToLocalTime().ToString("MM/dd/yyyy HH:mm") : "—")</td>
                        <td class="col-process"><small>@log.CurrentProcess</small></td>
                        <td>
                            @if (log.Status == "Completed")
                            {
                                <span class="tlog-badge-completed">Completed</span>
                            }
                            else
                            {
                                <span class="tlog-badge-inprogress">In Progress</span>
                            }
                        </td>
                        <td class="col-remarks">@(string.IsNullOrEmpty(log.Remarks) ? "—" : log.Remarks)</td>
                        <td class="col-action">
                            <button class="btn-history" onclick="openHistory('@log.TransactionNumber')">
                                View
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Custom pagination — outside scroll wrapper so it never scrolls ── *@
    <div class="tlog-dt-bottom">
        <span id="customInfo" class="tlog-dt-info-text"></span>
        <div id="customPaginate" class="tlog-custom-paginate"></div>
    </div>

</div>

@* ── History Modal ── *@
<div id="historyModalBackdrop" class="history-backdrop" style="display:none;">
    <div class="history-modal">
        <div class="history-modal-header">
            <span id="historyModalTitle">History</span>
            <button onclick="closeHistory()" class="history-close">✕</button>
        </div>
        <div class="history-modal-body">
            <div class="history-table-wrap">
                <table id="historyTable" class="table table-sm">
                    <thead>
                        <tr>
                            <th>Part Name</th>
                            <th>Supplier</th>
                            <th>Model</th>
                            <th>Activity</th>
                            <th>Source</th>
                            <th>PIC</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Input Date</th>
                            <th>Current Process</th>
                            <th>Status</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

