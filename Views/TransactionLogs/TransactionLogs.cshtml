                function openHistory(transactionNumber) {
            document.getElementById('historyModalTitle').textContent = 'History — ' + transactionNumber;
            document.getElementById('historyTableBody').innerHTML =
                '<tr><td colspan="12" class="text-center text-muted py-3">Loading...</td></tr>';
            document.getElementById('historyModalBackdrop').style.display = 'flex';

            // ── Use Razor-generated URL instead of hardcoded path ──
            var baseUrl = document.getElementById('getHistoryUrl').dataset.url;
            var url     = baseUrl + '?transactionNumber=' + encodeURIComponent(transactionNumber);

            fetch(url)
                .then(function (res) {
                    if (!res.ok) throw new Error('Server returned ' + res.status);
                    return res.json();
                })
                .then(function (data) {
                    var tbody = document.getElementById('historyTableBody');
                    if (!data || data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="12" class="text-center text-muted py-3">No history found.</td></tr>';
                        return;
                    }
                    tbody.innerHTML = data.map(function (row) {
                        var sourceBadge = row.source === 'Import File'
                            ? '<span class="tlog-source-import">Import File</span>'
                            : '<span class="tlog-source-activity">Update Activity</span>';
                        var statusBadge = row.status === 'Completed'
                            ? '<span class="tlog-badge-completed">Completed</span>'
                            : '<span class="tlog-badge-inprogress">In Progress</span>';
                        return '<tr>'
                            + '<td>' + (row.partName       || '—') + '</td>'
                            + '<td>' + (row.supplier       || '—') + '</td>'
                            + '<td>' + (row.model          || '—') + '</td>'
                            + '<td><span class="tlog-badge-activity">' + (row.activity || '—') + '</span></td>'
                            + '<td>' + sourceBadge + '</td>'
                            + '<td>' + (row.pic            || '—') + '</td>'
                            + '<td>' + (row.startDate      || '—') + '</td>'
                            + '<td>' + (row.endDate        || '—') + '</td>'
                            + '<td>' + (row.inputDate      || '—') + '</td>'
                            + '<td><small>' + (row.currentProcess || '—') + '</small></td>'
                            + '<td>' + statusBadge + '</td>'
                            + '<td>' + (row.remarks        || '—') + '</td>'
                            + '</tr>';
                    }).join('');
                })
                .catch(function (err) {
                    console.error('History fetch error:', err);
                    document.getElementById('historyTableBody').innerHTML =
                        '<tr><td colspan="12" class="text-center text-danger py-3">Failed to load history: ' + err.message + '</td></tr>';
                });
        }

        function closeHistory() {
            document.getElementById('historyModalBackdrop').style.display = 'none';
        }

        document.getElementById('historyModalBackdrop').addEventListener('click', function (e) {
            if (e.target === this) closeHistory();
        });
    </script>
