@model List<PartsControlSystem.Models._4mForm>

<div class="table-responsive" style="max-height:480px; overflow:auto;">
    <table id="formUpdateTable" class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Supplier Submission Date</th>
                <th>Target Implementation Date</th>
                <th>Company Name</th>
                <th>Supplier PIC</th>
                <th colspan="3">Control Number</th>
                <th>PQC PIC</th>
                <th>Attachment</th>
                <th class="text-center">Update</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                var groupedData = Model.GroupBy(x => x.ControlNumber).ToList();
                int groupIndex = 1;

                foreach (var group in groupedData)
                {
                    var header = group.First();
                    string collapseId = $"collapse-{groupIndex}";

                    <!-- ================= PARENT ROW ================= -->
                    <tr class="table-primary"
                        style="cursor:pointer"
                        data-bs-toggle="collapse"
                        data-bs-target="#@collapseId"
                        aria-expanded="false">

                        <td>@groupIndex</td>
                        <td>@header.SupplierSubmissionDate.ToString("yyyy-MM-dd")</td>
                        <td>@header.TargetImplementationDate.ToString("yyyy-MM-dd")</td>
                        <td>@header.CompanyName</td>
                        <td>@header.SupplierPIC</td>

                        <td colspan="3">
                            <strong>@header.ControlNumber</strong>
                            <span class="badge bg-secondary ms-2">
                                @group.Count() item(s)
                            </span>
                        </td>

                        <td>@header.PQCPIC</td>

                        <!-- Attachment -->
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(header.AttachmentPath))
                            {
                                <a class="btn btn-sm btn-outline-primary"
                                               href="@Url.Action("DownloadAttachmentExcel", "_4mForm", new { id = header.Id })">
                                    <i class="fa-solid fa-download"></i>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No Attachment</span>
                            }
                        </td>

                        <!-- UPDATE (PARENT LEVEL) -->
                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-sm btn-success"
                                    data-bs-toggle="modal"
                                    data-bs-target="#updateModal-@header.ControlNumber">
                                <i class="fa-solid fa-file-pdf me-1"></i> Update
                            </button>
                        </td>

                        <!-- EXPAND -->
                        <td class="text-center">
                            <i class="fa-solid fa-chevron-down"></i>
                        </td>
                    </tr>

                    <!-- ================= CHILD ROW ================= -->
                    <tr class="collapse" id="@collapseId">
                        <td colspan="11" class="p-0">
                            <table class="table table-sm table-striped mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Type of Change</th>
                                        <th>Part Code</th>
                                        <th>Part Name</th>
                                        <th>Change Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group)
                                    {
                                        <tr>
                                            <td>@item.TypeOfChange</td>
                                            <td>@item.PartCode</td>
                                            <td>@item.PartName</td>
                                            <td>@item.ChangeReason</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </td>
                    </tr>

                    groupIndex++;
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center text-muted">
                        No submissions yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ================= UPDATE MODALS ================= -->
@foreach (var group in Model?.GroupBy(x => x.ControlNumber) ?? Enumerable.Empty<IGrouping<string, PartsControlSystem.Models._4mForm>>())
{
    var header = group.First();
    <div class="modal fade" id="updateModal-@header.ControlNumber" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-4 shadow">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        Upload updated form for <strong>@header.ControlNumber</strong>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <form enctype="multipart/form-data" id="updateForm-@header.ControlNumber">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="FormId" value="@header.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Select Excel File (.xls, .xlsx)</label>
                            <input type="file" class="form-control" name="UpdatedPdf" accept=".xls,.xlsx" required />
                        </div>
                    </form>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary upload-btn" data-control="@header.ControlNumber">
                        <i class="fa-solid fa-cloud-arrow-up me-2"></i> Upload
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<!-- ================= STYLES ================= -->
<style>
    #formUpdateTable thead th {
        position: sticky;
        top: 0;
        background-color: #f8f9fa;
        z-index: 2;
    }

    tr[aria-expanded="true"] .fa-chevron-down {
        transform: rotate(180deg);
        transition: transform 0.2s ease;
    }
</style>

<!-- ================= SCRIPTS ================= -->

