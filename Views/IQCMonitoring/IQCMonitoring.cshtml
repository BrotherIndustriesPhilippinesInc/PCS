@functions {
    string Fmt(DateTime? d) => d.HasValue ? d.Value.ToLocalTime().ToString("MM/dd/yyyy") : "—";
}

<script>
       const panelMap = { renewal:'panel-renewal', multi:'panel-multi', supplier:'panel-supplier', local:'panel-local', change:'panel-change', o4m:'panel-o4m' };
    const cardMap  = { renewal:'cards-renewal', multi:'cards-multi', supplier:'cards-supplier', local:'cards-local', change:'cards-change', o4m:'cards-o4m' };

    function switchActivity(val) {
        Object.values(panelMap).forEach(id => document.getElementById(id)?.classList.remove('active'));
        Object.values(cardMap).forEach(id => { const el = document.getElementById(id); if (el) el.style.display = 'none'; });
        document.getElementById(panelMap[val])?.classList.add('active');
        const cards = document.getElementById(cardMap[val]);
        if (cards) cards.style.display = 'flex';
        document.getElementById('txtSearch').value = '';
    }

    const colMap = { txn:'txn', type:'type', cat:'cat', part:'part', model:'model', pending:'pending' };
    function filterTable() {
        const activity = document.getElementById('ddlActivity').value;
        const colKey   = document.getElementById('ddlSearchColumn').value;
        const keyword  = document.getElementById('txtSearch').value.trim().toLowerCase();
        const tbl      = document.getElementById('tbl-' + activity);
        if (!tbl) return;
        const attr = 'data-' + colMap[colKey];
        tbl.querySelectorAll('tbody tr').forEach(tr => {
            const val = (tr.getAttribute(attr) || '').toLowerCase();
            tr.style.display = (!keyword || val.includes(keyword)) ? '' : 'none';
        });
    }

    // ── Download — calls server-side ClosedXML action ──
    function downloadTable() {
        const activity = document.getElementById('ddlActivity').value;
        window.location.href = `/IQCMonitoring/Download?activity=${encodeURIComponent(activity)}`;
    }
</script>