@{
    ViewData["Title"] = "Dashboard";

    var activityStats = ViewBag.ActivityStats as Dictionary<string, (int Done, int Ongoing, int Delay)>
                        ?? new Dictionary<string, (int, int, int)>();

    var delayDetails = ViewBag.DelayDetails as List<(string Section, int DelayItems, int DaysDelay)>
                       ?? new List<(string, int, int)>();

    int totalDone    = ViewBag.TotalDone    ?? 0;
    int totalOngoing = ViewBag.TotalOngoing ?? 0;
    int totalDelay   = ViewBag.TotalDelay   ?? 0;

    var sections        = ViewBag.Sections as List<string> ?? new List<string>();
    string selectedSection  = ViewBag.SelectedSection as string ?? "";
    string selectedStart    = ViewBag.SelectedStartDate as string ?? "";
    string selectedEnd      = ViewBag.SelectedEndDate   as string ?? "";

    var activityCards = new[]
    {
        "Renewal / Additional Mold",
        "New Tooling / Localization",
        "Supplier Change / Localization",
        "Multiple Procurement / Localization",
        "Transfer Tooling",
        "Change Material",
        "New Model",
        "Non-Concurrent",
        "Other 4M"
    };
}

@Html.AntiForgeryToken()

<!-- Add this anywhere in Dashboard.cshtml, outside any form -->
<input type="hidden" id="notifySectionUrl" value="@Url.Action("NotifySection", "Home")" />

<div class="card mb-4 shadow">
    <div class="card-header">
        <i class="fa-solid fa-table-list"></i>
        Section Parts Progress
    </div>
    <div class="row p-4">

        <!-- Left Section -->
        <div class="col-xl-6 col-lg-6 col-md-12">

            <!-- Overall Completion Rate -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <i class="fa-solid fa-table-list"></i>
                    Overall Completion Rate
                    @if (!string.IsNullOrWhiteSpace(selectedSection))
                    {
                        <span class="badge bg-white text-dark ms-2">@selectedSection</span>
                    }
                </div>
                <div class="p-2">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr><th>Done</th>   <td>@totalDone</td></tr>
                            <tr><th>Ongoing</th><td>@totalOngoing</td></tr>
                            <tr><th>Delay</th>  <td>@totalDelay</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Data Selection Filter -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <i class="fa-solid fa-filter"></i>
                    Data Selection
                </div>
                <div class="p-3 bg-light">
                    <form method="get" asp-action="Dashboard" asp-controller="Home">

                        <div class="form-group mb-3">
                            <label for="section" class="form-label fw-semibold">Section</label>
                            <select name="section" id="section" class="form-select">
                                <option value="">-- All Sections --</option>
                                @foreach (var s in sections)
                                {
                                    <option value="@s" selected="@(selectedSection == s ? "selected" : null)">
                                            @s
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label for="startDate" class="form-label fw-semibold">Start Date</label>
                            <input type="date" name="startDate" id="startDate"
                                   class="form-control" value="@selectedStart" />
                        </div>

                        <div class="form-group mb-3">
                            <label for="endDate" class="form-label fw-semibold">End Date</label>
                            <input type="date" name="endDate" id="endDate"
                                   class="form-control" value="@selectedEnd" />
                        </div>

                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-magnifying-glass me-1"></i> Filter
                            </button>
                            <a asp-action="Dashboard" asp-controller="Home" class="btn btn-outline-secondary">
                                <i class="fa-solid fa-xmark me-1"></i> Clear
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>


        <div class="col-xl-6 col-lg-6 col-md-12">
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    Delay by Section
                </div>
                <div class="p-2">
                    <table class="table table-bordered text-center align-middle">
                        <thead>
                            <tr>
                                <th>Section</th>
                                <th>No. of Delay Items</th>
                                <th>No. of Days Delay</th>
                                <th>Notify Section</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (delayDetails.Any())
                            {
                                @foreach (var row in delayDetails)
                                {
                                    <tr>
                                        <td>@row.Section</td>
                                        <td>@row.DelayItems</td>
                                        <td>@row.DaysDelay</td>
                                        <td>
                                            <button class="btn btn-link p-0 btn-notify"
                                                    data-section="@row.Section"
                                                    title="Notify @row.Section">
                                                <i class="bi bi-bell-fill text-info" style="font-size: 20px;"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-muted text-center py-3">
                                        <i class="fa-solid fa-circle-check text-success me-1"></i>
                                        No delays found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Per-Activity Cards -->
<div class="row">
    @foreach (var activityName in activityCards)
    {
        var stats = activityStats.ContainsKey(activityName)
            ? activityStats[activityName]
            : (Done: 0, Ongoing: 0, Delay: 0);

        <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header">
                    <i class="fa-solid fa-table-list"></i>
                    @activityName
                </div>
                <div class="p-2">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr><th>Done</th>   <td>@stats.Done</td></tr>
                            <tr><th>Ongoing</th><td>@stats.Ongoing</td></tr>
                            <tr><th>Delay</th>  <td>@stats.Delay</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="border border-dark border-5">
    <script type='module' src='https://bi.datalake.brother.co.jp/javascripts/api/tableau.embedding.3.latest.min.js'></script>
    <div class="h-100 w-100">
        <tableau-viz id='tableau-viz' src='https://bi.datalake.brother.co.jp/t/biph/views/PartsControlSystemStatus/Dashboard1/55f04bda-8fe1-4c61-b493-4e5cfdc8b355/05a8c1c5-c0d6-4572-b4c7-e9af26119d75' width="100%" height="100vh" hide-tabs toolbar='bottom'></tableau-viz>
    </div>
</div>
<script type="module" src="https://embedding.tableau.com/api/tableau.embedding.3.latest.min.js"></script>

@section Scripts {
    <script>
           document.querySelectorAll('.btn-notify').forEach(btn => {
        btn.addEventListener('click', function () {
            const section = this.dataset.section;
            const url = document.getElementById('notifySectionUrl').value; // ← dynamic

            Swal.fire({
                icon: 'question',
                title: 'Send Notification?',
                text: `Send delay notification email to section: ${section}?`,
                showCancelButton: true,
                confirmButtonText: 'Yes, Notify',
                cancelButtonText: 'Cancel'
            }).then(result => {
                if (!result.isConfirmed) return;

                fetch(url, {  // ← uses the razor-generated url
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: `section=${encodeURIComponent(section)}`
                })
                .then(r => r.json())
                .then(data => {
                    Swal.fire({
                        icon: data.success ? 'success' : 'error',
                        title: data.success ? 'Sent!' : 'Failed',
                        text: data.message,
                        timer: 3000,
                        showConfirmButton: false
                    });
                })
                .catch(() => {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Request failed.' });
                });
            });
        });
    });
          (async function() {
          const viz = document.getElementById("tableau-viz");

            async function refreshTableauVizData() {
              swal.fire({
                title: "Refreshing Tableau Data...",
                allowOutsideClick: false,
                didOpen: () => {
                  swal.showLoading();
                }
              });

              try {
                await viz.refreshDataAsync();
                swal.close();

                console.log("Tableau data refreshed successfully");
              } catch (e) {
                console.error("Tableau refresh failed:", e);
                swal.fire("Error", "Failed to refresh Tableau data.", "error");
              }
            }

            // Example: auto refresh every 5 minutes
            setInterval(refreshTableauVizData, 5 * 60 * 1000);

            // Or manual button
            window.refreshTableauVizData = refreshTableauVizData;
        })();

    </script>
}