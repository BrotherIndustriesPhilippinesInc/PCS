                            <th style="text-align:center">Lead Time (Days)</th>
                        </tr>
                    </thead>
                    <tbody id="cm-tbody">
                        @foreach (var item in Model.ChangeMaterialSteps)
                        {
                            <tr data-id="@item.Id" data-original="@item.LeadTime" data-type="changematerial">
                                <td><span class="step-badge">@item.StepOrder</span></td>
                                <td>@item.ProcessStep</td>
                                <td><span class="section-pill">@item.Section</span></td>
                                <td>
                                    <div class="lt-input-wrap">
                                        <input type="number" class="lt-input lt-val" min="0" step="0.5"
                                               value="@item.LeadTime"
                                               onchange="markDirty(this)" />
                                        <span class="lt-unit">days</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Toast container -->
<div class="lt-toast-container" id="toastContainer"></div>


    <script>
        // ── Tab switching ──────────────────────────────────────────────
        function switchTab(name, btn) {
            document.querySelectorAll('.lt-tab-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.lt-tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }

        // ── Mark row as dirty (edited) ─────────────────────────────────
        function markDirty(input) {
            const original = parseFloat(input.closest('tr').dataset.original);
            const current  = parseFloat(input.value);
            if (current !== original) {
                input.classList.add('dirty');
            } else {
                input.classList.remove('dirty');
            }
        }

        // ── Reset all dirty fields in a tab ───────────────────────────
        function resetDirty(tbodyId, tabKey) {
            const rows = document.querySelectorAll(`#${tbodyId} tr[data-id]`);
            rows.forEach(row => {
                const input = row.querySelector('.lt-val');
                if (!input) return;
                input.value = row.dataset.original;
                input.classList.remove('dirty');
            });
            showToast('Changes discarded.', false, 'info');
        }

        // ── Search/filter ──────────────────────────────────────────────
        function filterTable(tbodyId, term, countId, total) {
            const q = term.toLowerCase().trim();
            const rows = document.querySelectorAll(`#${tbodyId} tr[data-id]`);
            let visible = 0;
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                const show = !q || text.includes(q);
                row.classList.toggle('filtered-out', !show);
                if (show) visible++;
            });
            const badge = document.getElementById(countId);
            if (badge) badge.textContent = q ? `${visible} of ${total}` : `${total} activities`;
        }

        // ── Bulk save ──────────────────────────────────────────────────
        async function saveAll(tabKey) {
            const tbodyMap = { renewal: 'renewal-tbody', mp: 'mp-tbody', sc: 'sc-tbody', loc: 'loc-tbody', cm: 'cm-tbody' };
            const tbody = document.getElementById(tbodyMap[tabKey]);
            const rows  = tbody.querySelectorAll('tr[data-id]');

            // Collect ALL rows (send even unchanged so backend has full picture — or filter dirty only)
            const updates = [];
            rows.forEach(row => {
                const input = row.querySelector('.lt-val');
                if (!input) return;
                const val = parseFloat(input.value);
                if (!isNaN(val)) {
                    updates.push({ id: parseInt(row.dataset.id), value: val });
                }
            });

            if (!updates.length) {
                showToast('Nothing to save.', false, 'info');
                return;
            }

            // Determine endpoint
            let endpoint;
                if (tabKey === 'renewal') {
                    endpoint = '/LeadTime/SaveAllRenewal';
                } else if (tabKey === 'cm') {
                    endpoint = '/LeadTime/SaveAllChangeMaterial';
                } else {
                    endpoint = '/LeadTime/SaveAllTooling';
                }
            const saveBtn    = document.getElementById(`btn-save-${tabKey}`);

            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving…';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const res   = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(updates)
                });

                const data = await res.json();

                if (data.success) {
                    // Update originals so dirty detection resets
                    rows.forEach(row => {
                        const input = row.querySelector('.lt-val');
                        if (!input) return;
                        row.dataset.original = input.value;
                        input.classList.remove('dirty');
                        row.classList.add('row-saved');
                        setTimeout(() => row.classList.remove('row-saved'), 1300);
                    });
                    showToast(data.message, true);
                } else {
                    showToast(data.message || 'Save failed.', false);
                }
            } catch (err) {
                showToast('Network error. Please try again.', false);
                console.error(err);
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
            }
        }

        // ── Toast helper ───────────────────────────────────────────────
        function showToast(message, success = true, type = null) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            const isSuccess = type === 'info' ? null : success;

            toast.className = `lt-toast ${type === 'info' ? '' : (success ? 'success' : 'error')}`;

            let icon = success
                ? '<i class="fa-solid fa-circle-check"></i>'
                : '<i class="fa-solid fa-circle-xmark"></i>';
            if (type === 'info') icon = '<i class="fa-solid fa-circle-info" style="color:var(--lt-primary)"></i>';

            toast.innerHTML = `${icon} <span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3500);
        }
    </script>

