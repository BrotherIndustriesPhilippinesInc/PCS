                        <i class="fa-solid fa-xmark me-1"></i> Discard
                    </button>
                    <button class="btn-lt-save" id="btn-save-sc" onclick="saveAll('sc')">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                </div>
            </div>

            <div class="lt-table-wrap">
                <table class="lt-table">
                    <thead>
                        <tr>
                            <th>Step</th>
                            <th>Process Step</th>
                            <th>Section</th>
                            <th style="text-align:center">Lead Time (Days)</th>
                        </tr>
                    </thead>
                    <tbody id="sc-tbody">
                        @foreach (var item in Model.SupplierChangeSteps)
                        {
                            <tr data-id="@item.Id" data-original="@item.LeadTimeDays" data-type="tooling">
                                <td><span class="step-badge">@item.StepOrder</span></td>
                                <td>@item.ProcessStep</td>
                                <td><span class="section-pill">@item.Section</span></td>
                                <td>
                                    <div class="lt-input-wrap">
                                        <input type="number" class="lt-input lt-val" min="0" step="0.5"
                                               value="@item.LeadTimeDays"
                                               onchange="markDirty(this)" />
                                        <span class="lt-unit">days</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         TAB 4 — LOCALIZATION
    ═══════════════════════════════════════════════════════════ -->
    <div id="tab-loc" class="lt-tab-pane">
        <div class="lt-card">
            <div class="lt-toolbar">
                <div class="lt-toolbar-left">
                    <span class="lt-count-badge" id="loc-count">@Model.LocalizationSteps.Count steps</span>
                    <input type="text" class="lt-search" placeholder="Search step or section…"
                           oninput="filterTable('loc-tbody', this.value, 'loc-count', @Model.LocalizationSteps.Count)" />
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-lt-reset" onclick="resetDirty('loc-tbody', 'loc')">
                        <i class="fa-solid fa-xmark me-1"></i> Discard
                    </button>
                    <button class="btn-lt-save" id="btn-save-loc" onclick="saveAll('loc')">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                </div>
            </div>

            <div class="lt-table-wrap">
                <table class="lt-table">
                    <thead>
                        <tr>
                            <th>Step</th>
                            <th>Process Step</th>
                            <th>Section</th>
                            <th style="text-align:center">Lead Time (Days)</th>
                        </tr>
                    </thead>
                    <tbody id="loc-tbody">
                        @foreach (var item in Model.LocalizationSteps)
                        {
                            <tr data-id="@item.Id" data-original="@item.LeadTimeDays" data-type="tooling">
                                <td><span class="step-badge">@item.StepOrder</span></td>
                                <td>@item.ProcessStep</td>
                                <td><span class="section-pill">@item.Section</span></td>
                                <td>
                                    <div class="lt-input-wrap">
                                        <input type="number" class="lt-input lt-val" min="0" step="0.5"
                                               value="@item.LeadTimeDays"
                                               onchange="markDirty(this)" />
