    </div>
    <!-- ═══════════════════════════════════════════════════════════
         TAB 5 — CHANGE MATERIAL
    ═══════════════════════════════════════════════════════════ -->
    <div id="tab-cm" class="lt-tab-pane">
        <div class="lt-card">
            <div class="lt-toolbar">
                <div class="lt-toolbar-left">
                    <span class="lt-count-badge" id="cm-count">@Model.ChangeMaterialSteps.Count steps</span>
                    <input type="text" class="lt-search" placeholder="Search step or section…"
                           oninput="filterTable('cm-tbody', this.value, 'cm-count', @Model.ChangeMaterialSteps.Count)" />
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-lt-reset" onclick="resetDirty('cm-tbody', 'cm')">
                        <i class="fa-solid fa-xmark me-1"></i> Discard
